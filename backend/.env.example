# Database - Use Neon PostgreSQL
# Formato: postgresql://user:password@host/database
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname

# Security
SECRET_KEY=your-secret-key-here-change-this

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS Origins (separadas por vírgula para produção)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://sticker-book-2026.vercel.app
